{
    "name": "blackstone/laravel-model-translations-sync",
    "description": "Synchronize Laravel model translations between models, language_lines, files and external translation flows.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-translatable": "^6.11",
        "spatie/laravel-translation-loader": "^2.8"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "BlackstonePro\\ModelTranslationsSync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlackstonePro\\ModelTranslationsSync\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlackstonePro\\ModelTranslationsSync\\ModelTranslationsSyncServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit"
    }
}
